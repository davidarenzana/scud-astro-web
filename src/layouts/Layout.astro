---
import { Font } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCurrentLocale, type Locale } from "../utils/i18n";
import "../styles/global.css";

import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";

const currentLocale = getCurrentLocale(Astro);
const locales: Locale[] = ["es", "ca", "en"];

// Obtener la ruta sin prefijo de idioma para generar hreflang
const pathname = Astro.url.pathname;
const pathWithoutLocale = pathname
  .replace(/^\/(ca|en)\//, "/")
  .replace(/^\/$/, "");

// Mapeo de locales a códigos de idioma HTML
const langMap: Record<Locale, string> = {
  es: "es-ES",
  ca: "ca-ES",
  en: "en-US",
};
---

<!doctype html>
<html lang={langMap[currentLocale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/scud-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-lato" />
    <title>Astro Basics</title>

    <!-- hreflang links para SEO multiidioma -->
    {
      locales.map((locale) => (
        <link
          rel="alternate"
          hreflang={locale}
          href={getRelativeLocaleUrl(locale, pathWithoutLocale)}
        />
      ))
    }
    <link rel="canonical" href={Astro.url.pathname} />
  </head>
  <body class="bg-background text-white">
    <Header />
    <main class="max-w-[1440px] mx-auto px-4 w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
