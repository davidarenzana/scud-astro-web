---
export interface NavItem {
  key: string
  label: string
  href: string
}

export interface Props {
  navItems: NavItem[]
}

const { navItems } = Astro.props
---

<nav class="w-full">
  <!-- Navigation Menu -->
  <ul
    id="nav-menu"
    class="hidden lg:flex list-none gap-0 lg:gap-4 p-0 m-0 font-normal flex-col lg:flex-row lg:items-center fixed lg:static left-0 right-0 top-[102px] lg:top-0 bg-background-glass lg:bg-transparent z-40 lg:z-auto w-full lg:w-auto max-h-[calc(100vh-102px)] lg:max-h-none overflow-y-auto lg:overflow-y-visible border-t-2 lg:border-t-0 border-gradient-border"
  >
    {
      navItems.map((item) => (
        <li class="px-6 lg:px-0 py-4 lg:py-0 hover:text-fucsia transition-colors duration-200 border-b lg:border-b-0 border-gray-700/50 hover:border-fucsia/30 last:border-b-0">
          <a href={item.href} class="block text-base font-medium">
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  import { getMenuElements, isMenuOpen } from '../../utils/menuManager'

  const elements = getMenuElements()
  if (!elements) throw new Error('Menu elements not found')

  const { menu, hamburger, lines } = elements

  // The hamburger button handles all interactions
  // This script just ensures cleanup on navigation (no need to close menu on link click here)
</script>

<style>
  #nav-menu {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-background-glass) 95%, var(--color-fucsia) 5%),
      var(--color-background-glass)
    );
    border-image: linear-gradient(to right, var(--color-fucsia) 0%, var(--color-cyan) 100%) 1;
  }
</style>
