---
import Layout from '../../layouts/Layout.astro'
import { getCurrentLocale, getPageI18n } from '../../utils/i18n'

const locale = getCurrentLocale(Astro)
const i18n = await getPageI18n('services', locale)
---

<Layout>
  <section class="py-16">
    <h1 class="text-4xl font-bold mb-2">{i18n.title}</h1>
    <p class="text-xl text-gray mb-8">{i18n.subtitle}</p>
    <p class="text-lg mb-12">{i18n.description}</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        Array.isArray(i18n.services) &&
          i18n.services.map((service) => (
            <div class="border border-gray-light rounded-lg p-6 hover:shadow-lg transition">
              <h3 class="text-xl font-bold mb-2">{service.name}</h3>
              <p class="text-gray">{service.description}</p>
            </div>
          ))
      }
    </div>
  </section>
</Layout>
